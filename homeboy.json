{
  "id": "wp-codebox",
  "extensions": {
    "nodejs": {}
  },
  "build_command": "npm run package:wordpress-plugin",
  "build_artifact": "packages/wordpress-plugin/dist/wp-codebox.zip",
  "version_targets": [
    {
      "file": "package.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\""
    },
    {
      "file": "packages/runtime-core/package.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\""
    },
    {
      "file": "packages/runtime-playground/package.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\""
    },
    {
      "file": "packages/cli/package.json",
      "pattern": "\"version\":\\s*\"([0-9.]+)\""
    }
  ],
  "self_checks": {
    "lint": [
      "npm run build"
    ],
    "test": [
      "npm run package-distribution-smoke",
      "npm run release:package"
    ]
  }
}
