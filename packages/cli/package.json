{
  "name": "@chubes4/wp-codebox-cli",
  "version": "0.0.0",
  "description": "WP Codebox CLI — secure coding environments inside WordPress. Run disposable Playground sandboxes that can't touch your host site.",
  "type": "module",
  "bin": {
    "wp-codebox": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@chubes4/wp-codebox-core": "file:../runtime-core",
    "@chubes4/wp-codebox-playground": "file:../runtime-playground"
  }
}
