{
  "schema": "wp-codebox/preview-options-contract/v1",
  "options": {
    "preview_hold_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3600,
      "description": "Seconds to keep the live Playground preview URL available after capture. Max 3600 by default; operators may raise the cap with WP_CODEBOX_PREVIEW_HOLD_MAX_SECONDS."
    },
    "preview_port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "description": "Optional fixed local WP Codebox preview proxy port. Omit to keep the default loopback-only random-port behavior."
    },
    "preview_bind": {
      "type": "string",
      "description": "Optional fixed-port preview proxy bind host or IP. Requires preview_port. Defaults to 127.0.0.1 when omitted."
    },
    "preview_public_url": {
      "type": "string",
      "format": "uri",
      "description": "Optional public http/https URL reported in preview metadata and passed to the sandbox for site URL alignment."
    },
    "preview_lease": {
      "type": "object",
      "description": "Optional wp-codebox/preview-lease/v1 envelope for external tunnel/public URL handoff metadata. WP Codebox reports it but does not create the tunnel."
    }
  },
  "cases": [
    {
      "name": "empty input",
      "input": {},
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 0,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "valid fixed preview",
      "input": {
        "preview_hold_seconds": "30",
        "preview_port": "45678",
        "preview_bind": "127.0.0.1",
        "preview_public_url": "https://preview.example.test/session-123/"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 30,
        "preview_port": 45678,
        "preview_bind": "127.0.0.1",
        "preview_public_url": "https://preview.example.test/session-123/",
        "preview_lease": null
      }
    },
    {
      "name": "valid lease envelope derives public url",
      "input": {
        "preview_lease": {
          "schema": "wp-codebox/preview-lease/v1",
          "public_url": "https://preview.example.test/session-lease/",
          "local_url": "http://127.0.0.1:45678/",
          "lease": {
            "status": "active",
            "expires_at": "2026-06-22T13:00:00.000Z",
            "provider": "example-tunnel"
          },
          "alignment": {
            "status": "aligned"
          }
        }
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 0,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": "https://preview.example.test/session-lease/",
        "preview_lease": {
          "schema": "wp-codebox/preview-lease/v1",
          "public_url": "https://preview.example.test/session-lease/",
          "preview_public_url": "https://preview.example.test/session-lease/",
          "local_url": "http://127.0.0.1:45678/",
          "lease": {
            "status": "active",
            "expires_at": "2026-06-22T13:00:00.000Z",
            "provider": "example-tunnel"
          },
          "alignment": {
            "status": "aligned"
          },
          "evidence_refs": []
        }
      }
    },
    {
      "name": "minute preview hold syntax",
      "input": {
        "preview_hold_seconds": "2m"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 120,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "hold clamps above maximum",
      "input": {
        "preview_hold_seconds": "7200"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 3600,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "hour preview hold syntax clamps to default cap",
      "input": {
        "preview_hold_seconds": "2h"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 3600,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": null
      }
    },
    {
      "name": "port minimum",
      "input": {
        "preview_port": "1"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 0,
        "preview_port": 1,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "port maximum",
      "input": {
        "preview_port": "65535"
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 0,
        "preview_port": 65535,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "empty optional values are omitted",
      "input": {
        "preview_port": " ",
        "preview_bind": " ",
        "preview_public_url": " "
      },
      "valid": true,
      "normalized": {
        "preview_hold_seconds": 0,
        "preview_port": null,
        "preview_bind": null,
        "preview_public_url": null,
        "preview_lease": null
      }
    },
    {
      "name": "bind requires port",
      "input": {
        "preview_bind": "0.0.0.0"
      },
      "valid": false,
      "code": "wp_codebox_preview_bind_requires_port"
    },
    {
      "name": "invalid port zero",
      "input": {
        "preview_port": "0"
      },
      "valid": false,
      "code": "wp_codebox_preview_port_invalid"
    },
    {
      "name": "invalid port non-integer",
      "input": {
        "preview_port": "12.5"
      },
      "valid": false,
      "code": "wp_codebox_preview_port_invalid"
    },
    {
      "name": "invalid bind url",
      "input": {
        "preview_port": "45678",
        "preview_bind": "http://127.0.0.1"
      },
      "valid": false,
      "code": "wp_codebox_preview_bind_invalid"
    },
    {
      "name": "invalid bind whitespace",
      "input": {
        "preview_port": "45678",
        "preview_bind": "bad host"
      },
      "valid": false,
      "code": "wp_codebox_preview_bind_invalid"
    },
    {
      "name": "invalid public url scheme",
      "input": {
        "preview_public_url": "file:///tmp/preview"
      },
      "valid": false,
      "code": "wp_codebox_preview_public_url_invalid"
    },
    {
      "name": "invalid public url hostname",
      "input": {
        "preview_public_url": "https://"
      },
      "valid": false,
      "code": "wp_codebox_preview_public_url_invalid"
    },
    {
      "name": "invalid lease schema",
      "input": {
        "preview_lease": {
          "schema": "example/preview-lease/v1",
          "public_url": "https://preview.example.test/session-lease/"
        }
      },
      "valid": false,
      "code": "wp_codebox_preview_lease_invalid"
    }
  ]
}
